# Obrigatório
GROQ_API_KEY=gsk-your-key-here

# Modelo e temperatura (baseline)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Tópico padrão (opcional — CLI usa --topic)
RESEARCH_TOPIC=Impacto da inteligência artificial na saúde pública no Brasil

# MongoDB (opcional; descomente para persistir os relatórios)
# MONGODB_URI=mongodb://localhost:27017/

# LangGraph — guardrails e engenharia de contexto (opcional; padrão: ativos)
# LANGGRAPH_GUARDRAILS=true
# LANGGRAPH_CONTEXT_ENGINEERING=true
# LANGGRAPH_CONTEXT_MAX_CHARS=1500
# LANGGRAPH_NOTES_MAX_POINTS=6
# LANGGRAPH_INPUT_MAX_CHARS=2000

# LangChain — guardrails e engenharia de contexto (opcional; padrão: ativos)
# LANGCHAIN_GUARDRAILS=true
# LANGCHAIN_CONTEXT_ENGINEERING=true
# LANGCHAIN_CONTEXT_MAX_CHARS=1500
# LANGCHAIN_NOTES_MAX_POINTS=6
# LANGCHAIN_INPUT_MAX_CHARS=2000
